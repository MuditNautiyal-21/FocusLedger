{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/extension",
    "rootDir": "src/extension",
    "declaration": false,
    "lib": ["ES2022", "DOM"],
    "types": ["chrome"],
    "removeComments": true
  },
  "include": ["src/extension/**/*.ts"],
  "exclude": ["node_modules"]
}
